{
  "compilerOptions": {
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "composite": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2018", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "outDir": "build",
    "pretty": true,
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "target": "esnext"
  },
  "include": ["main.ts", "src/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules"]
}
